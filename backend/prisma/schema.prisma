datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPPORT
  OWNER
  ADMIN
  ENGINEER
  OPERATOR
  VIEWER
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Company {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                 User[]
  projects              Project[]
  stocks                Stock[]
  inventoryTransactions InventoryTransaction[]
  optimizationJobs      OptimizationJob[]
  reports               Report[]
}

model User {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role      @default(VIEWER)
  companyId    Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company       Company        @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  companyId Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company          Company           @relation(fields: [companyId], references: [id])
  orders           Order[]
  optimizationJobs OptimizationJob[]
}

model Stock {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company      Company       @relation(fields: [companyId], references: [id])
  stockLengths StockLength[]
}

model StockLength {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockId   Int
  length    Int // in mm
  quantity  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stock Stock @relation(fields: [stockId], references: [id])
}

model Order {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project    Project     @relation(fields: [projectId], references: [id])
  orderItems OrderItem[]
}

model OrderItem {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   Int
  length    Int // in mm
  quantity  Int
  diameter  Int // in mm
  label     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  order Order @relation(fields: [orderId], references: [id])
}

model OptimizationJob {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId Int
  projectId Int
  status    JobStatus @default(PENDING)
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company             Company              @relation(fields: [companyId], references: [id])
  project             Project              @relation(fields: [projectId], references: [id])
  optimizationResults OptimizationResult[]
}

model OptimizationResult {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId     Int
  summary   Json // Total waste, utilization %, bars, cost metrics
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  job             OptimizationJob  @relation(fields: [jobId], references: [id])
  cuttingPatterns CuttingPattern[]
  leftovers       Leftover[]
}

model CuttingPattern {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId  Int
  barNumber Int
  cuts      Json // Array of cut lengths
  waste     Int // in mm
  weight    Float // in kg
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  result OptimizationResult @relation(fields: [resultId], references: [id])
}

model Leftover {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId  Int
  length    Int // in mm
  quantity  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  result OptimizationResult @relation(fields: [resultId], references: [id])
}

model InventoryTransaction {
  id        Int             @id @default(autoincrement())
  uuid      String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId Int
  type      TransactionType
  quantity  Int
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])
}

model Report {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId Int
  title     String
  filePath  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
